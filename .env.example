# ─── Multi-Agent AI Platform — Environment Variables ─────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-256-bit-key
DEBUG=true

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=ollama
OPENAI_DEFAULT_MODEL=llama3:latest
# ── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/multiagent

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017/multiagent

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── Ollama (local LLM) ───────────────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434/v1

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── CORS (comma-separated) ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:80
